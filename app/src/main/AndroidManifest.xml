<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.loginappmario_gerry">

    <application
        android:allowBackup="true"
        android:icon="@drawable/nova_logo_pap"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.LoginAppMario_Gerry">

        <!-- Tela de pedidos de oração -->
        <activity
            android:name=".pedido_oracaoActivity2"
            android:exported="false" />

        <!-- Tela de eventos -->
        <activity
            android:name=".EventosActivity"
            android:exported="false" />

        <activity
            android:name=".HomeActivity2"
            android:exported="true" />

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Tela de cadastro -->
        <activity
            android:name=".SignupActivity2"
            android:exported="true" />

    </application>
</manifest>